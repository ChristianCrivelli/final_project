SELECT education_level, COUNT(*) AS count
FROM ingestion.users_data
GROUP BY education_level
ORDER BY count DESC


SELECT employment_status, COUNT(*) AS count
FROM ingestion.users_data
GROUP BY employment_status
ORDER BY count DESC


SELECT *
FROM ingestion.users_data
